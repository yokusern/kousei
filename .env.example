# Kousei - AI Style Analyzer Environment Variables

# ===========================================
# LLM API Settings (Optional - for future implementation)
# ===========================================

# Enable LLM-based analysis (default: false)
# Set to "true" to enable LLM refinement of highlights
# LLM_ENABLED=true

# LLM Provider: "openai" | "anthropic" | "gemini"
# LLM_PROVIDER=openai

# Model to use for analysis
# ANALYSIS_MODEL=gpt-4o-mini

# OpenAI API Key (if using OpenAI)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (if using Anthropic)
# ANTHROPIC_API_KEY=sk-...

# Google AI API Key (if using Google Gemini)
# GOOGLE_AI_API_KEY=AIza...

# ===========================================
# Application Settings
# ===========================================

# Max number of history items to store in localStorage
# HISTORY_LIMIT=5

# Max number of highlights to return
# MAX_HIGHLIGHTS=5
