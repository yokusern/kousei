# Kousei - AI Style Analyzer Environment Variables

# ===========================================
# LLM API Settings
# ===========================================

# Enable LLM-based refinement
# LLM_ENABLED=true

# LLM API Endpoint
# LLM_API_URL=https://api.anthropic.com/v1/messages

# LLM API Key
# LLM_API_KEY=sk-ant-...

# Model to use
# LLM_MODEL=claude-3-5-sonnet-20250620

# OpenAI API Key (if using OpenAI)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (if using Anthropic)
# ANTHROPIC_API_KEY=sk-...

# Google AI API Key (if using Google Gemini)
# GOOGLE_AI_API_KEY=AIza...

# ===========================================
# Application Settings
# ===========================================

# Default analysis mode: "proposal" or "note"
# DEFAULT_MODE=proposal

# Max number of history items to store in localStorage
# HISTORY_LIMIT=5

# Max number of highlights to display
# MAX_HIGHLIGHTS=5
